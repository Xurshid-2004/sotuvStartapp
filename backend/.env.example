# ===== Backend muhit o'zgaruvchilari namunasi =====
# Bu faylni .env deb nusxalang va qiymatlarni to'ldiring.
# cp .env.example .env

# Maxfiy kalit (production'da ALBATTA o'zgartiring):
# yangi kalit: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-dev-only-CHANGE-ME

# Production'da False qiling
DEBUG=True

# Vergul bilan ajratilgan domenlar (production)
ALLOWED_HOSTS=localhost,127.0.0.1,testserver

# Ma'lumotlar bazasi. Bo'sh qoldirilsa — SQLite (dev).
# PostgreSQL uchun: postgres://user:parol@host:5432/dbname
DATABASE_URL=
DB_SSL=False

# Frontend manzillari (CORS)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=

# JWT token muddati
JWT_ACCESS_MIN=60
JWT_REFRESH_DAYS=7

# So'rovlarni cheklash (DDoS himoyasi)
THROTTLE_ANON=60/min
THROTTLE_USER=1000/min

# Vaqt mintaqasi
TIME_ZONE=Asia/Tashkent

# Production HTTPS (DEBUG=False bo'lganda)
SECURE_SSL_REDIRECT=True
